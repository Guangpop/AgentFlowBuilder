{
  "name": "agentflow-mcp",
  "version": "1.0.0",
  "description": "MCP Server for AI Agent workflow generation with visual editor",
  "type": "module",
  "bin": {
    "agentflow-mcp": "./bin/agentflow-mcp.js"
  },
  "main": "./dist/mcp/server.js",
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "dev:mcp": "tsx src/cli.ts",
    "dev:web": "tsx src/cli.ts serve --dev",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "ai", "agent", "workflow", "claude"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^4.21.0",
    "chokidar": "^4.0.0",
    "open": "^10.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
