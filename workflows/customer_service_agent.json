        "customer_message"
      ],
      "next": [
        "classify_intent"
      ],
      "position": {
        "x": 100,
        "y": 100
      }
    },
    {
      "node_id": "classify_intent",
      "node_type": "AgentReasoning",
      "description": "分析客戶訊息，分類問題意圖（產品諮詢、技術支援、帳號問題、投訴建議、退換貨）",
