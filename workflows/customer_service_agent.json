        "customer_message"
      ],
      "outputs": [
        "intent_category",
        "sentiment_score",
        "urgency_level"
      ],
      "next": [
        "check_urgency"
      ],
      "position": {
        "x": 550,
        "y": 100
      }
    },
    {
      "node_id": "check_urgency",
      "node_type": "Condition",
      "description": "判斷是否為緊急或高情緒問題（urgency_level >= high 或 sentiment_score < 0.3）",
      "inputs": [
        "urgency_level",
        "sentiment_score"
      ],
      "outputs": [
        "is_urgent"
      ],
      "next": [
        "escalate_to_human",
        "search_knowledge_base"
      ],
      "position": {
        "x": 1000,
        "y": 100
      }
    },
    {
      "node_id": "search_knowledge_base",
