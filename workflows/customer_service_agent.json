        "customer_message",
        "intent_category"
      ],
      "outputs": [
        "search_results",
        "confidence_score"
      ],
      "next": [
        "check_confidence"
      ],
      "config": {
        "toolName": "knowledge_base_search"
      },
      "position": {
        "x": 100,
        "y": 450
      }
    },
    {
      "node_id": "check_confidence",
      "node_type": "Condition",
      "description": "判斷知識庫搜尋結果的信心度是否足夠（confidence_score >= 0.7）",
