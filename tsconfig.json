{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/shared/**/*",
    "src/mcp/**/*",
    "src/web/**/*",
    "src/cli.ts"
  ],
  "exclude": [
    "src/web-app/**/*",
    "node_modules",
    "dist"
  ]
}
