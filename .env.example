# AI Agent Workflow Builder - Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# LOCAL DEVELOPMENT ONLY
# ===========================================
# Use your own Claude API key for local development
# Get your key at: https://console.anthropic.com/settings/keys
VITE_LOCAL_API_KEY=

# Optional: Gemini for local development
# Get your key at: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# ===========================================
# ANONYMOUS MODE (Demo/Trial)
# ===========================================
# Enable anonymous payment mode (no login required)
# Users can pay and use services without registration
# Set to 'true' to enable
VITE_ANONYMOUS_MODE=

# ===========================================
# Supabase (Required for both Local & Production)
# ===========================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# Gumroad Payment (Frontend)
# ===========================================
# Strategy: 'A' (postMessage + license verify) or 'B' (webhook + polling)
VITE_PAYMENT_STRATEGY=A
# Your Gumroad username (e.g. "yourname" for yourname.gumroad.com)
VITE_GUMROAD_SELLER_HANDLE=
# Short product permalink slugs from Gumroad dashboard
VITE_GUMROAD_WORKFLOW_PRODUCT_ID=
VITE_GUMROAD_SOP_PRODUCT_ID=

# ===========================================
# PRODUCTION ONLY (Set in Vercel Dashboard, NOT here!)
# ===========================================
# These are server-side only and must NOT have VITE_ prefix
#
# ANTHROPIC_API_KEY=sk-ant-xxx          # Backend API calls
# SUPABASE_SERVICE_ROLE_KEY=xxx         # Backend admin access
# GUMROAD_PRODUCT_WORKFLOW_ID=xxx       # Gumroad product ID for workflow
# GUMROAD_PRODUCT_SOP_ID=xxx           # Gumroad product ID for SOP
# GUMROAD_SECRET=xxx                    # Gumroad webhook secret (Strategy B only)
# GUMROAD_TEST_MODE=true               # Skip real Gumroad API calls (dev only)
# ANONYMOUS_MODE=true                   # Enable anonymous mode (backend)
#
# WARNING: NEVER set VITE_LOCAL_API_KEY in Vercel!
# The build will fail if both VITE_LOCAL_API_KEY and ANTHROPIC_API_KEY are set.
